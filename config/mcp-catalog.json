{
  "googleDrive": {
    "displayName": "Google Drive",
    "kind": "mcp",
    "transport": "stdio",
    "runner": "npx",
    "trustLevel": "day-one-node-default",
    "officialness": "trusted-third-party",
    "authFriction": "medium",
    "runtime": "node",
    "dataExposure": "local-mcp-to-google-apis",
    "writeCapability": "read-only-default",
    "riskLevel": "medium",
    "lastVerified": "2026-06-18",
    "author": "piotr-agier",
    "source": "https://github.com/piotr-agier/google-drive-mcp",
    "authMode": "company_oauth_browser",
    "package": "@piotr-agier/google-drive-mcp@latest",
    "url": null,
    "serverName": "google-drive",
    "defaultProvider": "google-drive-local-node-fallback",
    "requiredScopes": [
      "https://www.googleapis.com/auth/drive.readonly"
    ],
    "credentialKeys": [
      "GOOGLE_OAUTH_CLIENT_JSON",
      "GDRIVE_CREDENTIALS_PATH"
    ],
    "optionalCredentialKeys": [
      "GOOGLE_CLIENT_ID",
      "GOOGLE_CLIENT_SECRET",
      "GOOGLE_ADC_CLIENT_JSON",
      "GDRIVE_OAUTH_PATH"
    ],
    "authCommand": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts\\WebAnalystSetup.ps1 -Action GoogleOAuthFile; powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts\\WebAnalystSetup.ps1 -Action RunMcp -ServerName google-drive -Runner npx -Package \"@piotr-agier/google-drive-mcp@latest\" -McpArgs auth",
    "notes": "Default day-one Node path for Google Drive because it is easy to run locally with npx and browser OAuth. It is not Google official and can request broad Drive/Docs/Sheets/Slides/Calendar scopes depending on configuration, so use current-company approved OAuth credentials and prefer read-only scopes where possible. Use provider google-drive-official-remote when the selected MCP client and company policy support Google's official remote MCP custom OAuth route.",
    "testPrompt": "List 5 recent Google Drive files.",
    "providers": {
      "google-drive-official-remote": {
        "displayName": "Google Drive (official remote fallback)",
        "transport": "http",
        "runner": null,
        "trustLevel": "first-party-preview",
        "officialness": "first-party",
        "authFriction": "high",
        "runtime": "remote",
        "dataExposure": "google-remote-mcp",
        "writeCapability": "optional-drive-file",
        "riskLevel": "medium",
        "lastVerified": "2026-06-18",
        "author": "Google Workspace",
        "source": "https://developers.google.com/workspace/drive/api/guides/configure-mcp-server",
        "authMode": "static_oauth_client",
        "package": null,
        "url": "https://drivemcp.googleapis.com/mcp/v1",
        "serverName": "google-drive",
        "requiredScopes": [
          "https://www.googleapis.com/auth/drive.readonly",
          "https://www.googleapis.com/auth/drive.file"
        ],
        "requiredGoogleServices": [
          "drive.googleapis.com",
          "drivemcp.googleapis.com"
        ],
        "credentialKeys": [
          "GOOGLE_CLIENT_ID",
          "GOOGLE_CLIENT_SECRET"
        ],
        "optionalCredentialKeys": [
          "GOOGLE_PROJECT_ID"
        ],
        "authCommand": null,
        "notes": "Google's official Drive remote MCP in Developer Preview. Prefer this when the selected MCP client can pass static OAuth client credentials for remote MCP servers and company policy allows it.",
        "testPrompt": "List 5 recent Google Drive files."
      }
    }
  },

{
  "profiles": {
    "minimal": {
      "description": "Smallest useful setup: browser QA only, no account credentials.",
      "tools": {
        "browserQa": {
          "enabled": true,
          "provider": "playwright-official-mcp"
        }
      }
    },
    "google-workspace": {
      "description": "Google Drive and Gmail day-one setup with local Node MCP defaults.",
      "tools": {
        "googleDrive": {
          "enabled": true,
          "provider": "google-drive-local-node-fallback"
        },
        "gmail": {
          "enabled": true,
          "provider": "gmail-local-node-fallback"
        }
      }
    },
    "analytics-core": {
      "description": "Core web analyst stack for Google analytics/tagging plus browser QA.",
      "tools": {
        "googleTagManager": {
          "enabled": true,
          "provider": "stape-gtm-remote-oauth"
        },
        "googleAnalytics": {
          "enabled": true,
          "provider": "googleanalytics-official-adc"
        },
        "bigQuery": {
          "enabled": true,
          "provider": "google-bigquery-official-remote-mcp"
        },
        "browserQa": {
          "enabled": true,
          "provider": "playwright-official-mcp"
        }
      }
    },
    "browser-testing": {
      "description": "Browser automation and debugging profile for QA, consent, and dataLayer tests.",
      "tools": {
        "browserQa": {
          "enabled": true,
          "provider": "playwright-official-mcp"
        },
        "browserDebug": {
          "enabled": true,
          "provider": "chrome-devtools-official-mcp"
        }
      }
    },
    "full-web-analyst": {
      "description": "Broad first-day web analyst profile. Use only when the company approves all selected tools.",
      "tools": {
        "googleDrive": {
          "enabled": true,
          "provider": "google-drive-local-node-fallback"
        },
        "gmail": {
          "enabled": true,
          "provider": "gmail-local-node-fallback"
        },
        "googleTagManager": {
          "enabled": true,
          "provider": "stape-gtm-remote-oauth"
        },
        "googleAnalytics": {
          "enabled": true,
          "provider": "googleanalytics-official-adc"
        },
        "bigQuery": {
          "enabled": true,
          "provider": "google-bigquery-official-remote-mcp"
        },
        "browserQa": {
          "enabled": true,
          "provider": "playwright-official-mcp"
        },
        "browserDebug": {
          "enabled": true,
          "provider": "chrome-devtools-official-mcp"
        },
        "pianoAnalyticsApi": {
          "enabled": true,
          "provider": "api-connector"
        },
        "tagCommander": {
          "enabled": true,
          "provider": "api-connector"
        },
        "contentsquare": {
          "enabled": true,
          "provider": "contentsquare-official-mcp"
        }
      }
    }
  }
